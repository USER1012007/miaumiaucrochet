---
  import { SITE_DESCRIPTION } from '../consts.ts';

  const allImages = import.meta.glob('../assets/**/*.{jpg,jpeg,png,webp,avif}', { eager: true });
  const allSrcs: string[] = Object.values(allImages).map(
    (mod) => mod.default?.src ?? mod.default ?? ''
  ).filter(Boolean);

  const allSrcsJSON = JSON.stringify(allSrcs);

---
<section class="hero">
  <div class="hero__bg-pattern"></div>
  <div class="hero__content">
    <div class="hero__badge">✦ Catálogo de Peluches Crochet ✦</div>
    <h1 class="hero__title">
      Bienvenid@ a mi<br/>
      <span class="hero__title-script">Catálogo de Peluches Crochet</span><br/>
      { SITE_DESCRIPTION }
    </h1>

<div class="hero__about">
  <div class="hero__about-header">
    <div class="hero__about-avatar">M</div>
    <div>
      <div class="hero__about-name">Hola, soy Mariel 💓</div>
      <div class="hero__about-tag">✦ Creadora de amigurumis</div>
    </div>
  </div>
  <p class="hero__about-text">
    Me encanta crear cosas hechas a mano y por eso empecé a hacer amigurumis. 
    Lo que comenzó como un hobby se convirtió en una forma de compartir mis 
    creaciones con otras personas.
  </p>
  <p class="hero__about-text">
    Hago amigurumis y llaveros tejidos a mano, cada uno con mucho cuidado y 
    dedicación. Me gusta crear piezas únicas que puedan ser un regalo especial 
    o un lindo recuerdo.
  </p>
  <div class="hero__about-footer">
    <span>🫶🏻 Gracias por apoyar el trabajo hecho a mano</span>
  </div>
</div>

    <div class="hero__currency-note">
      <div class="hero__currency-item">
        <span class="hero__flag">💸</span>
        <span>Pago en <strong>Efectivo</strong></span>
      </div>
      <div class="hero__currency-divider"></div>
      <div class="hero__currency-item">
        <span class="hero__flag">💳</span>
        <span>Pago con <strong>Transferencia</strong></span>
      </div>
      <div class="hero__currency-item">
        <span>
          <strong>Para la cotización de tu pedido:</strong> <br/>
          Mandar por mensaje una imagén de
          referencia, junto con las especificaciones
          de tu interés (tamaño, color, etc).
        </span>
      </div>
      <div class="hero__currency-item">
        <span>
          El <strong>tiempo de entrega</strong> puede variar entre
          <strong>5 a 15 días</strong>, dependiendo de lo que se
          solicite puede existir un cambio.
        </span>
      </div>

      <div class="hero__currency-item">
        <span>En pedidos mayores a <strong>$300.00</strong> se solicita un anticipo del <strong>50%</strong></span>
      </div>

    </div>
    <div class="hero__ctas">
      <a href="#catalog" class="hero__cta-primary">Ver Catálogo</a>
      <a href="#quotes" class="hero__cta-secondary">Cotizaciones</a>
    </div>
  </div>
  <div class="hero__visual">

    <div class="hero__mosaic" id="heroMosaic">
      {[1,2,3,4,5,6].map(i => (
        <div class={`hero__mosaic-card hero__mosaic-card--${i}`}>
          <img src="" alt="" loading="lazy" />
        </div>
      ))}
    </div>

    <div class="hero__mosaic-label">@miaumiaucrochet</div>
  </div>
</section>

<style>
.hero__about {
  background: var(--warm-white);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px 22px;
  margin-bottom: 32px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  position: relative;
  overflow: hidden;
}
.hero__about::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--rose), var(--brown-light));
  border-radius: 3px 0 0 3px;
}
.hero__about-header {
  display: flex;
  align-items: center;
  gap: 12px;
}
.hero__about-avatar {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--rose), var(--brown-light));
  color: #fff;
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(181,99,76,0.3);
}
.hero__about-name {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-dark);
  line-height: 1.3;
}
.hero__about-tag {
  font-size: 11px;
  color: var(--rose);
  font-weight: 700;
  letter-spacing: 0.08em;
}
.hero__about-text {
  font-size: 13px;
  color: var(--text-mid);
  line-height: 1.75;
  padding-left: 4px;
}
.hero__about-footer {
  font-size: 12px;
  color: var(--text-light);
  border-top: 1px solid var(--border);
  padding-top: 10px;
  font-style: italic;
}
.hero {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
  padding: 80px 24px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  overflow: hidden;
}
.hero__bg-pattern {
  position: absolute;
  inset: 0;
  background-image: 
    radial-gradient(circle at 10% 20%, rgba(212,131,106,0.06) 0%, transparent 50%),
    radial-gradient(circle at 90% 80%, rgba(196,168,152,0.08) 0%, transparent 50%);
  pointer-events: none;
}
.hero__content {
  animation: fadeInUp 0.8s ease both;
}
.hero__badge {
  display: inline-block;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rose);
  background: rgba(212,131,106,0.1);
  padding: 6px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
  font-weight: 700;
}
.hero__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 500;
  color: var(--text-dark);
  line-height: 1.2;
  margin-bottom: 20px;
}
.hero__title-script {
  font-family: 'Dancing Script', cursive;
  font-size: clamp(2.2rem, 4.5vw, 3.6rem);
  color: var(--rose);
  font-weight: 600;
}
.hero__subtitle {
  font-size: 15px;
  color: var(--text-mid);
  line-height: 1.7;
  margin-bottom: 28px;
  max-width: 440px;
}
.hero__currency-note {
  display: flex;
  align-items: center;
  gap: 16px;
  background: var(--warm-white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 18px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}
.hero__currency-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text-mid);
}
.hero__flag { font-size: 18px; }
.hero__currency-divider {
  width: 1px;
  height: 28px;
  background: var(--border);
}
.hero__ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.hero__cta-primary {
  background: var(--rose);
  color: #fff;
  padding: 13px 28px;
  border-radius: 30px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.04em;
  transition: all 0.25s;
  box-shadow: 0 4px 16px rgba(181,99,76,0.25);
}
.hero__cta-primary:hover {
  background: var(--rose-dark);
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(181,99,76,0.35);
}
.hero__cta-secondary {
  border: 1.5px solid var(--rose);
  color: var(--rose);
  padding: 13px 28px;
  border-radius: 30px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.04em;
  transition: all 0.25s;
}
.hero__cta-secondary:hover {
  background: var(--rose);
  color: #fff;
  transform: translateY(-2px);
}
.hero__visual {
  position: relative;
  animation: fadeIn 1s ease 0.3s both;
}
.hero__mosaic {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(2, 180px);
  gap: 8px;
}
.hero__mosaic-card {
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(60,30,20,0.12);
  transition: transform 0.3s ease;
}
.hero__mosaic-card:hover { transform: scale(1.04); z-index: 2; }
.hero__mosaic-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero__mosaic-card--1 { grid-column: 1; grid-row: 1; border-radius: 40px 12px 12px 12px; }
.hero__mosaic-card--2 { grid-column: 2; grid-row: 1; }
.hero__mosaic-card--3 { grid-column: 3; grid-row: 1; border-radius: 12px 40px 12px 12px; }
.hero__mosaic-card--4 { grid-column: 1; grid-row: 2; border-radius: 12px 12px 12px 40px; }
.hero__mosaic-card--5 { grid-column: 2; grid-row: 2; }
.hero__mosaic-card--6 { grid-column: 3; grid-row: 2; border-radius: 12px 12px 40px 12px; animation: float 4s ease-in-out infinite; }
.hero__mosaic-label {
  text-align: center;
  margin-top: 12px;
  font-family: 'Dancing Script', cursive;
  font-size: 18px;
  color: var(--rose);
}

@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    padding: 50px 24px 40px;
    gap: 40px;
  }
  .hero__mosaic { grid-template-rows: repeat(2, 140px); }
}
</style>

<script define:vars={{ allSrcsJSON }}>
  const srcs = JSON.parse(allSrcsJSON);

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const picked = shuffle(srcs).slice(0, 6);

  document.querySelectorAll('#heroMosaic .hero__mosaic-card img').forEach((img, i) => {
    img.src = picked[i];
    img.alt = `Crochet ${i + 1}`;
  });
</script>
