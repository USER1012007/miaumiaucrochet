---
import LOGO from '../../public/logo.png';
import { SITE_TITLE } from '../consts.ts';
import { Image } from 'astro:assets';

const navLinks = [
  { label: "Inicio", href: "#home" },
  { label: "Catálogo", href: "#catalog" },
  { label: "Cotizaciones", href: "#quotes" },
];
---

<header class="navbar">
  <div class="navbar__top-bar">
    <span class="navbar__currency">México</span>
  </div>

  <div class="navbar__main">
    <div class="navbar__logo-wrap">
      <div class="navbar__logo-icon">
        <Image src={ LOGO } alt="Logo" width="40" height="40")/>
      </div>
      <div class="navbar__logo-text">
        <span class="navbar__logo-name">{ SITE_TITLE }</span>
      </div>
    </div>

    <nav class="navbar__nav">
      {navLinks.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </nav>

    <div class="navbar__actions">
        <span></span><span></span><span></span>
    </div>
  </div>

  <nav class="navbar__mobile" id="mobile-menu">
    {navLinks.map(link => (
      <a href={link.href} class="navbar__mobile-link">{link.label}</a>
    ))}
  </nav>
</header>

<style>
.navbar {
  background: var(--warm-white);
  border-bottom: 1px solid var(--border);
  position: sticky;
  justify-content: center;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 12px rgba(180,120,100,0.06);
}
.navbar__top-bar {
  background: var(--blush);
  text-align: center;
  padding: 6px 16px;
  font-size: 11.5px;
  color: var(--text-mid);
  letter-spacing: 0.05em;
}
.navbar__main {
  max-width: 1200px;
  margin: 0 auto;
  padding: 14px 24px;
  display: flex;
  align-items: center;
  gap: 24px;
}
.navbar__logo-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.navbar__logo-text {
  display: flex;
  flex-direction: column;
}
.navbar__logo-name {
  font-family: 'Playfair Display', serif;
  font-size: 15px;
  font-weight: 600;
  color: var(--text-dark);
  line-height: 1.2;
}
.navbar__logo-sub {
  font-family: 'Dancing Script', cursive;
  font-size: 13px;
  color: var(--rose);
  line-height: 1.2;
}
.navbar__nav {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
  justify-content: center;
  flex-wrap: wrap;
}
.navbar__link {
  font-size: 12.5px;
  font-weight: 400;
  color: var(--text-mid);
  padding: 6px 10px;
  border-radius: 4px;
  transition: color 0.2s, background 0.2s;
  letter-spacing: 0.02em;
  white-space: nowrap;
}
.navbar__link:hover {
  color: var(--rose);
  background: rgba(212,131,106,0.08);
}
.navbar__actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
.navbar__btn {
  font-family: 'Lato', sans-serif;
  font-size: 12px;
  background: none;
  border: 1.5px solid var(--rose);
  color: var(--rose);
  padding: 7px 14px;
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.navbar__btn:hover { background: var(--rose); color: #fff; }
.navbar__cart {
  position: relative;
  color: var(--text-mid);
  transition: color 0.2s;
}
.navbar__cart:hover { color: var(--rose); }
.navbar__cart-count {
  position: absolute;
  top: -8px;
  right: -8px;
  background: var(--rose);
  color: #fff;
  font-size: 9px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.navbar__hamburger {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.navbar__hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text-mid);
  border-radius: 2px;
  transition: all 0.2s;
}
.navbar__mobile {
  display: none;
  flex-direction: column;
  background: var(--warm-white);
  border-top: 1px solid var(--border);
  padding: 12px 24px;
}
.navbar__mobile.open { display: flex; }
.navbar__mobile-link {
  padding: 10px 0;
  font-size: 14px;
  color: var(--text-mid);
  border-bottom: 1px solid var(--border);
  transition: color 0.2s;
}
.navbar__mobile-link:last-child { border-bottom: none; }
.navbar__mobile-link:hover { color: var(--rose); }

@media (max-width: 768px) {
  .navbar__nav { display: none; }
  .navbar__btn { display: none; }
  .navbar__hamburger { display: flex; }
}
</style>

<script>
const toggle = document.getElementById('menu-toggle');
const menu = document.getElementById('mobile-menu');
toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>
