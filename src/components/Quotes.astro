---

<section class="quotes">
  <div class="quotes__container">
    <div class="quotes__inner">
      <div class="quotes__text">
        <span class="quotes__eyebrow">Cotizaciones</span>
        <h2 class="quotes__title">¿Quieres un peluche<br/><em>personalizado?</em></h2>
        <p class="quotes__body">
          Comunícate mediante DM por cualquiera de mis redes sociales.<br/> 
          Con gusto te atiendo 🧶
        </p>
        <div class="quotes__socials">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener" class="quotes__social" style={`--sc: ${s.color}`}>
              <span set:html={s.icon}></span>
              {s.name}
            </a>
          ))}
        </div>
      </div>
      <div class="quotes__deco">
        <div class="quotes__deco-circle quotes__deco-circle--1"></div>
        <div class="quotes__deco-circle quotes__deco-circle--2"></div>
        <div class="quotes__deco-yarn">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="100" cy="100" r="80" stroke="#d4836a" stroke-width="2" stroke-dasharray="8 6" opacity="0.4"/>
            <circle cx="100" cy="100" r="55" stroke="#d4836a" stroke-width="2" stroke-dasharray="5 8" opacity="0.3"/>
            <circle cx="100" cy="100" r="30" stroke="#b5634c" stroke-width="2" opacity="0.5"/>
            <circle cx="100" cy="100" r="10" fill="#d4836a" opacity="0.6"/>
            <path d="M100 20 Q140 60 100 100 Q60 140 100 180" stroke="#b5634c" stroke-width="1.5" fill="none" opacity="0.4"/>
            <path d="M20 100 Q60 60 100 100 Q140 140 180 100" stroke="#c4a898" stroke-width="1.5" fill="none" opacity="0.4"/>
          </svg>
        </div>
        <div class="quotes__deco-text">{ SITE_TITLE }</div>
      </div>
    </div>
  </div>
</section>

<style>
.quotes {
  padding: 80px 24px;
  background: var(--warm-white);
  border-top: 1px solid var(--border);
}
.quotes__container { max-width: 1200px; margin: 0 auto; }
.quotes__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.quotes__eyebrow {
  display: inline-block;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--rose);
  font-weight: 700;
  margin-bottom: 14px;
}
.quotes__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  font-weight: 500;
  color: var(--text-dark);
  line-height: 1.25;
  margin-bottom: 18px;
}
.quotes__title em {
  font-style: italic;
  color: var(--rose);
}
.quotes__body {
  font-size: 15px;
  color: var(--text-mid);
  line-height: 1.7;
  margin-bottom: 32px;
  max-width: 400px;
}
.quotes__socials {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.quotes__social {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 30px;
  border: 1.5px solid var(--border);
  font-size: 13px;
  font-weight: 600;
  color: var(--text-dark);
  background: #fff;
  transition: all 0.25s;
}
.quotes__social:hover {
  border-color: var(--sc);
  color: var(--sc);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.08);
}
.quotes__social svg { flex-shrink: 0; }

/* Deco side */
.quotes__deco {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300px;
}
.quotes__deco-circle {
  position: absolute;
  border-radius: 50%;
}
.quotes__deco-circle--1 {
  width: 220px; height: 220px;
  background: radial-gradient(circle at 30% 40%, #f5e6d8, #edddd0);
  top: 10px; left: 10%;
  animation: float 5s ease-in-out infinite;
}
.quotes__deco-circle--2 {
  width: 120px; height: 120px;
  background: radial-gradient(circle, #f0d9c8, #e8ccbb);
  bottom: 20px; right: 5%;
  animation: float 7s ease-in-out infinite reverse;
}
.quotes__deco-yarn {
  position: relative;
  z-index: 2;
  width: 180px;
  height: 180px;
  animation: float 6s ease-in-out infinite;
}
.quotes__deco-text {
  position: absolute;
  bottom: 30px;
  font-family: 'Dancing Script', cursive;
  font-size: 22px;
  color: var(--rose);
  z-index: 3;
}

@media (max-width: 768px) {
  .quotes__inner { grid-template-columns: 1fr; gap: 40px; }
  .quotes__deco { display: none; }
}
</style>
