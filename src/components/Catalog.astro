---
import { Image } from 'astro:assets';

const allImages = import.meta.glob('../assets/**/*.{jpg,jpeg,png,webp,avif}', { eager: true });

function findImg(filename: string): string {
  const entry = Object.entries(allImages).find(([path]) =>
    path.split('/').pop()?.startsWith(filename)
  );
  return entry ? (entry[1].default?.src ?? entry[1].default ?? '') : '';
}

